# =============================================================================
# TRACKER OAUTH CONFIGURATION
# =============================================================================
# 
# AniList (REQUIRED - no default client ID):
#   1. Register at https://anilist.co/settings/developer
#   2. Create a new app with redirect URI: http://localhost:3000/tracker/callback/anilist
#   3. Use "Implicit Grant" flow (response_type=token)
#   4. No client secret needed
# 
# MyAnimeList (OPTIONAL - has default client ID):
#   1. Register at https://myanimelist.net/apiconfig if you want your own
#   2. Uses PKCE flow (code_challenge)
#   3. No client secret needed
# 
# =============================================================================

# REQUIRED for AniList: Your AniList app client ID
ANILIST_CLIENT_ID=your_anilist_client_id
ANILIST_REDIRECT_URI=http://localhost:3000/tracker/callback/anilist

# Optional: Override default MyAnimeList CLIENT_ID
# MAL_CLIENT_ID=your_mal_client_id
# MAL_REDIRECT_URI=http://localhost:3000/tracker/callback/mal

# =============================================================================
# ENCRYPTION KEY (Auto-generated on first run if not set)
# =============================================================================
# Used for encrypting stored OAuth tokens in the database
# For production, set this to a secure random 32-byte base64 string
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ENCRYPTION_KEY=your_base64_encryption_key_here
