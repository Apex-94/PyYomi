# =============================================================================
# TRACKER OAUTH CONFIGURATION
# =============================================================================
# 
# AniList (has built-in default client ID):
#   1. Register at https://anilist.co/settings/developer if you want your own app credentials.
#   2. Redirect URI is auto-derived from frontend origin (e.g. http://127.0.0.1:3000/tracker/callback/anilist).
#      You can override it with ANILIST_REDIRECT_URI.
#   3. Supports both:
#      - code flow (server app): requires client ID + client secret
#      - implicit flow (public client): requires client ID only
#   4. AniList access tokens are long-lived (~1 year), no refresh tokens
# 
# MyAnimeList (OPTIONAL - has default client ID):
#   1. Register at https://myanimelist.net/apiconfig if you want your own
#   2. Uses PKCE flow (code_challenge)
#   3. No client secret needed
# 
# =============================================================================

# Optional override for AniList default client ID
# ANILIST_CLIENT_ID=your_anilist_client_id
# Optional flow: auto | code | implicit (default: auto)
ANILIST_OAUTH_FLOW=auto
# Required only for code flow:
# ANILIST_CLIENT_SECRET=your_anilist_client_secret
# Optional redirect override (otherwise auto-derived from frontend origin)
# ANILIST_REDIRECT_URI=http://127.0.0.1:3000/tracker/callback/anilist

# Optional: Override default MyAnimeList CLIENT_ID
# MAL_CLIENT_ID=your_mal_client_id
# Optional redirect override (otherwise auto-derived from frontend origin)
# MAL_REDIRECT_URI=http://127.0.0.1:3000/tracker/callback/mal

# =============================================================================
# ENCRYPTION KEY (Auto-generated on first run if not set)
# =============================================================================
# Used for encrypting stored OAuth tokens in the database
# For production, set this to a secure random 32-byte base64 string
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ENCRYPTION_KEY=your_base64_encryption_key_here
