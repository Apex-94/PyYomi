{
  "name": "pyyomi-root",
  "private": true,
  "scripts": {
    "app:dev": "node scripts/app-cli.js dev",
    "app:release:win": "node scripts/app-cli.js release:win",
    "version:sync": "node scripts/app-cli.js version:sync",
    "version:bump": "node scripts/app-cli.js version:bump",
    "frontend:install": "npm install --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:typecheck": "cd frontend && npx tsc --noEmit",
    "backend:build-binary": "powershell -ExecutionPolicy Bypass -File backend/scripts/build_backend_binary.ps1",
    "electron:install": "npm install --prefix electron",
    "electron:dev": "npm run start --prefix electron",
    "electron:build": "npm run backend:build-binary && npm run frontend:build && npm run build --prefix electron",
    "electron:build:win": "npm run backend:build-binary && npm run frontend:build && npm run build:win --prefix electron"
  },
  "keywords": [
    "manga",
    "reader",
    "desktop",
    "pyyomi",
    "electron"
  ],
  "author": "Pyyomi",
  "license": "MIT",
  "description": "Manga Reader Desktop App - Electron Runtime",
  "dependencies": {
    "pyyomi": "file:frontend"
  }
}
